# =============================================================================
# Claw — Microservices Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.

# --- PostgreSQL: Auth Service (:5441) ---
PG_AUTH_USER=claw
PG_AUTH_PASSWORD=change-me
PG_AUTH_DB=claw_auth

# --- PostgreSQL: Chat Service (:5442) ---
PG_CHAT_USER=claw
PG_CHAT_PASSWORD=change-me
PG_CHAT_DB=claw_chat

# --- PostgreSQL: Connector Service (:5443) ---
PG_CONNECTOR_USER=claw
PG_CONNECTOR_PASSWORD=change-me
PG_CONNECTOR_DB=claw_connectors

# --- PostgreSQL: Routing Service (:5444) ---
PG_ROUTING_USER=claw
PG_ROUTING_PASSWORD=change-me
PG_ROUTING_DB=claw_routing

# --- PostgreSQL: Memory Service (:5445) ---
PG_MEMORY_USER=claw
PG_MEMORY_PASSWORD=change-me
PG_MEMORY_DB=claw_memory

# --- PostgreSQL: Files Service (:5446) ---
PG_FILES_USER=claw
PG_FILES_PASSWORD=change-me
PG_FILES_DB=claw_files

# --- MongoDB: Audit Service (:27017) ---
MONGO_USER=claw
MONGO_PASSWORD=change-me
MONGO_DB=claw_audit

# --- Redis (:6379) ---
REDIS_URL=redis://redis:6379

# --- RabbitMQ (:5672, management :15672) ---
RABBITMQ_URL=amqp://claw:change-me@rabbitmq:5672
RABBITMQ_USER=claw
RABBITMQ_PASSWORD=change-me

# --- JWT (shared across all services) ---
JWT_SECRET=change-me-to-a-random-64-char-string
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# --- Encryption (AES-256-GCM, 64 hex chars = 32 bytes) ---
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=change-me-to-a-random-32-byte-hex-string

# --- Admin Seed (Auth Service) ---
ADMIN_EMAIL=admin@claw.local
ADMIN_USERNAME=claw-admin
ADMIN_PASSWORD=change-me-on-first-login

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:80
NEXT_PUBLIC_APP_NAME=Claw
NEXT_PUBLIC_APP_URL=http://localhost:3000
FRONTEND_PORT=3000

# --- Ollama ---
OLLAMA_BASE_URL=http://ollama:11434

# --- General ---
NODE_ENV=development
