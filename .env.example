# =============================================================================
# Claw — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://claw:claw_secret@localhost:5432/claw?schema=public
POSTGRES_USER=claw
POSTGRES_PASSWORD=claw_secret
POSTGRES_DB=claw

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# Backend
# -----------------------------------------------------------------------------
BACKEND_PORT=4000
NODE_ENV=development

# JWT
JWT_SECRET=change-me-to-a-random-64-char-string
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Encryption (AES-256-GCM for connector secrets)
ENCRYPTION_KEY=change-me-to-a-random-32-byte-hex-string

# Default Admin Seed
ADMIN_EMAIL=admin@claw.local
ADMIN_USERNAME=claw-admin
ADMIN_PASSWORD=change-me-on-first-login

# -----------------------------------------------------------------------------
# Frontend
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:4000
FRONTEND_PORT=3000

# -----------------------------------------------------------------------------
# Ollama (Local AI Runtime)
# -----------------------------------------------------------------------------
OLLAMA_BASE_URL=http://localhost:11434

# -----------------------------------------------------------------------------
# Provider API Keys (Optional — configure via UI connectors)
# -----------------------------------------------------------------------------
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_GEMINI_API_KEY=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# DEEPSEEK_API_KEY=
