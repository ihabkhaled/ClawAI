# =============================================================================
# Connector Service Configuration
# =============================================================================

# PostgreSQL connection string for the connectors database
DATABASE_URL=postgresql://claw:claw_secret@localhost:5443/claw_connectors?schema=public

# Redis connection URL (shared instance for caching)
REDIS_URL=redis://localhost:6379

# RabbitMQ connection URL (shared async event bus)
RABBITMQ_URL=amqp://claw:claw_secret@localhost:5672

# JWT signing secret — must match auth service value
JWT_SECRET=change-me-to-a-random-64-char-string

# AES-256-GCM encryption key for connector API keys — CHANGE THIS in production
ENCRYPTION_KEY=change-me-to-a-random-32-byte-hex-string

# Service port
PORT=4003

# Allowed CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:80,http://localhost
