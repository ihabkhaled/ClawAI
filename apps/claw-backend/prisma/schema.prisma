generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgvector(map: "vector")]
}

// ─── Enums ───────────────────────────────────────────────

enum UserRole {
  ADMIN
  OPERATOR
  VIEWER
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  PENDING
}

enum ConnectorProvider {
  OPENAI
  ANTHROPIC
  GEMINI
  AWS_BEDROCK
  DEEPSEEK
  OLLAMA
}

enum ConnectorStatus {
  HEALTHY
  DEGRADED
  DOWN
  UNKNOWN
}

enum ConnectorAuthType {
  API_KEY
  OAUTH2
  NONE
}

enum ModelLifecycle {
  ACTIVE
  DEPRECATED
  SUNSET
}

enum RoutingMode {
  AUTO
  MANUAL_MODEL
  LOCAL_ONLY
  PRIVACY_FIRST
  LOW_LATENCY
  HIGH_REASONING
  COST_SAVER
}

enum MessageRole {
  SYSTEM
  USER
  ASSISTANT
  TOOL
}

enum MemoryType {
  SUMMARY
  FACT
  PREFERENCE
  INSTRUCTION
}

enum FileIngestionStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum AuditAction {
  LOGIN
  LOGOUT
  CREATE
  UPDATE
  DELETE
  ACCESS
  EXPORT
  IMPORT
  SETTINGS_CHANGE
  CONNECTOR_SYNC
  ROUTING_DECISION
}

enum AuditSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum LocalModelRole {
  ROUTER
  LOCAL_FALLBACK_CHAT
  LOCAL_REASONING
  LOCAL_CODING
}

enum ModelSyncStatus {
  RUNNING
  COMPLETED
  FAILED
}

// ─── Models ──────────────────────────────────────────────

model User {
  id                 String   @id @default(cuid())
  email              String   @unique
  username           String   @unique
  passwordHash       String   @map("password_hash")
  role               UserRole @default(VIEWER)
  status             UserStatus @default(PENDING)
  mustChangePassword Boolean  @default(false) @map("must_change_password")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  sessions      Session[]
  chatThreads   ChatThread[]
  memoryRecords MemoryRecord[]
  contextPacks  ContextPack[]
  files         File[]
  usageLedger   UsageLedgerEntry[]
  auditLogs     AuditLog[]

  @@index([email])
  @@index([status])
  @@map("users")
}

model Session {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  refreshToken String   @unique @map("refresh_token")
  expiresAt    DateTime @map("expires_at")
  createdAt    DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model Connector {
  id              String            @id @default(cuid())
  name            String
  provider        ConnectorProvider
  status          ConnectorStatus   @default(UNKNOWN)
  authType        ConnectorAuthType @map("auth_type")
  encryptedConfig String?           @map("encrypted_config")
  isEnabled       Boolean           @default(true) @map("is_enabled")
  defaultModelId  String?           @map("default_model_id")
  baseUrl         String?           @map("base_url")
  region          String?
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  models       ConnectorModel[]
  healthEvents ConnectorHealthEvent[]
  syncRuns     ModelSyncRun[]

  @@index([provider])
  @@index([status])
  @@index([isEnabled])
  @@map("connectors")
}

model ConnectorModel {
  id                      String            @id @default(cuid())
  connectorId             String            @map("connector_id")
  provider                ConnectorProvider
  modelKey                String            @map("model_key")
  displayName             String            @map("display_name")
  lifecycle               ModelLifecycle    @default(ACTIVE)
  supportsStreaming       Boolean           @default(false) @map("supports_streaming")
  supportsTools           Boolean           @default(false) @map("supports_tools")
  supportsVision          Boolean           @default(false) @map("supports_vision")
  supportsAudio           Boolean           @default(false) @map("supports_audio")
  supportsStructuredOutput Boolean          @default(false) @map("supports_structured_output")
  maxContextTokens        Int?              @map("max_context_tokens")
  syncedAt                DateTime          @default(now()) @map("synced_at")

  connector Connector @relation(fields: [connectorId], references: [id], onDelete: Cascade)

  @@unique([connectorId, modelKey])
  @@index([connectorId])
  @@index([provider])
  @@index([lifecycle])
  @@map("connector_models")
}

model ConnectorHealthEvent {
  id           String          @id @default(cuid())
  connectorId  String          @map("connector_id")
  status       ConnectorStatus
  latencyMs    Int?            @map("latency_ms")
  errorMessage String?         @map("error_message")
  checkedAt    DateTime        @default(now()) @map("checked_at")

  connector Connector @relation(fields: [connectorId], references: [id], onDelete: Cascade)

  @@index([connectorId])
  @@index([checkedAt])
  @@map("connector_health_events")
}

model ModelSyncRun {
  id            String          @id @default(cuid())
  connectorId   String          @map("connector_id")
  status        ModelSyncStatus
  modelsFound   Int             @default(0) @map("models_found")
  modelsAdded   Int             @default(0) @map("models_added")
  modelsRemoved Int             @default(0) @map("models_removed")
  startedAt     DateTime        @default(now()) @map("started_at")
  completedAt   DateTime?       @map("completed_at")
  errorMessage  String?         @map("error_message")

  connector Connector @relation(fields: [connectorId], references: [id], onDelete: Cascade)

  @@index([connectorId])
  @@index([status])
  @@map("model_sync_runs")
}

model ChatThread {
  id           String      @id @default(cuid())
  userId       String      @map("user_id")
  title        String?
  routingMode  RoutingMode @default(AUTO) @map("routing_mode")
  lastProvider String?     @map("last_provider")
  lastModel    String?     @map("last_model")
  isPinned     Boolean     @default(false) @map("is_pinned")
  isArchived   Boolean     @default(false) @map("is_archived")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages         ChatMessage[]
  routingDecisions RoutingDecision[]
  usageLedger      UsageLedgerEntry[]

  @@index([userId])
  @@index([isPinned])
  @@index([isArchived])
  @@index([createdAt])
  @@map("chat_threads")
}

model ChatMessage {
  id            String      @id @default(cuid())
  threadId      String      @map("thread_id")
  role          MessageRole
  content       String
  provider      String?
  model         String?
  routingMode   RoutingMode? @map("routing_mode")
  routerModel   String?     @map("router_model")
  usedFallback  Boolean     @default(false) @map("used_fallback")
  inputTokens   Int?        @map("input_tokens")
  outputTokens  Int?        @map("output_tokens")
  estimatedCost Decimal?    @map("estimated_cost") @db.Decimal(12, 8)
  latencyMs     Int?        @map("latency_ms")
  metadata      Json?
  createdAt     DateTime    @default(now()) @map("created_at")

  thread           ChatThread          @relation(fields: [threadId], references: [id], onDelete: Cascade)
  attachments      MessageAttachment[]
  routingDecisions RoutingDecision[]
  usageLedger      UsageLedgerEntry[]

  @@index([threadId])
  @@index([role])
  @@index([createdAt])
  @@map("chat_messages")
}

model MessageAttachment {
  id        String @id @default(cuid())
  messageId String @map("message_id")
  fileId    String @map("file_id")
  type      String

  message ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  file    File        @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@index([fileId])
  @@map("message_attachments")
}

model RoutingDecision {
  id               String      @id @default(cuid())
  messageId        String?     @map("message_id")
  threadId         String      @map("thread_id")
  selectedProvider String      @map("selected_provider")
  selectedModel    String      @map("selected_model")
  routingMode      RoutingMode @map("routing_mode")
  confidence       Decimal?    @db.Decimal(5, 4)
  reasonTags       String[]    @map("reason_tags")
  privacyClass     String?     @map("privacy_class")
  costClass        String?     @map("cost_class")
  fallbackProvider String?     @map("fallback_provider")
  fallbackModel    String?     @map("fallback_model")
  createdAt        DateTime    @default(now()) @map("created_at")

  message ChatMessage? @relation(fields: [messageId], references: [id], onDelete: SetNull)
  thread  ChatThread   @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@index([threadId])
  @@index([routingMode])
  @@index([createdAt])
  @@map("routing_decisions")
}

model RoutingPolicy {
  id          String      @id @default(cuid())
  name        String
  routingMode RoutingMode @map("routing_mode")
  priority    Int         @default(0)
  isActive    Boolean     @default(true) @map("is_active")
  config      Json
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  @@index([routingMode])
  @@index([isActive])
  @@index([priority])
  @@map("routing_policies")
}

model MemoryRecord {
  id              String     @id @default(cuid())
  userId          String     @map("user_id")
  type            MemoryType
  content         String
  sourceThreadId  String?    @map("source_thread_id")
  sourceMessageId String?    @map("source_message_id")
  isEnabled       Boolean    @default(true) @map("is_enabled")
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([isEnabled])
  @@map("memory_records")
}

model ContextPack {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  name        String
  description String?
  scope       String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user  User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  items ContextPackItem[]

  @@index([userId])
  @@map("context_packs")
}

model ContextPackItem {
  id            String   @id @default(cuid())
  contextPackId String   @map("context_pack_id")
  type          String
  content       String?
  fileId        String?  @map("file_id")
  sortOrder     Int      @default(0) @map("sort_order")
  createdAt     DateTime @default(now()) @map("created_at")

  contextPack ContextPack @relation(fields: [contextPackId], references: [id], onDelete: Cascade)
  file        File?       @relation(fields: [fileId], references: [id], onDelete: SetNull)

  @@index([contextPackId])
  @@index([sortOrder])
  @@map("context_pack_items")
}

model File {
  id              String              @id @default(cuid())
  userId          String              @map("user_id")
  filename        String
  mimeType        String              @map("mime_type")
  sizeBytes       Int                 @map("size_bytes")
  storagePath     String              @map("storage_path")
  ingestionStatus FileIngestionStatus @default(PENDING) @map("ingestion_status")
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")

  user             User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  chunks           FileChunk[]
  attachments      MessageAttachment[]
  contextPackItems ContextPackItem[]

  @@index([userId])
  @@index([ingestionStatus])
  @@map("files")
}

model FileChunk {
  id         String   @id @default(cuid())
  fileId     String   @map("file_id")
  chunkIndex Int      @map("chunk_index")
  content    String
  embedding  Unsupported("vector(1536)")?
  createdAt  DateTime @default(now()) @map("created_at")

  file File @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@index([fileId])
  @@index([chunkIndex])
  @@map("file_chunks")
}

model UsageLedgerEntry {
  id            String      @id @default(cuid())
  userId        String      @map("user_id")
  threadId      String?     @map("thread_id")
  messageId     String?     @map("message_id")
  provider      String
  model         String
  inputTokens   Int         @map("input_tokens")
  outputTokens  Int         @map("output_tokens")
  estimatedCost Decimal     @map("estimated_cost") @db.Decimal(12, 8)
  latencyMs     Int?        @map("latency_ms")
  routingMode   RoutingMode? @map("routing_mode")
  usedFallback  Boolean     @default(false) @map("used_fallback")
  createdAt     DateTime    @default(now()) @map("created_at")

  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  thread  ChatThread?  @relation(fields: [threadId], references: [id], onDelete: SetNull)
  message ChatMessage? @relation(fields: [messageId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([threadId])
  @@index([provider])
  @@index([createdAt])
  @@map("usage_ledger")
}

model AuditLog {
  id         String        @id @default(cuid())
  userId     String?       @map("user_id")
  action     AuditAction
  entityType String?       @map("entity_type")
  entityId   String?       @map("entity_id")
  severity   AuditSeverity @default(LOW)
  details    Json?
  ipAddress  String?       @map("ip_address")
  createdAt  DateTime      @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([severity])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

model SystemSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([key])
  @@map("system_settings")
}
