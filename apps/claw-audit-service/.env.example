# =============================================================================
# Audit Service Configuration (MongoDB)
# =============================================================================

# MongoDB connection URI for the audit database
MONGODB_URI=mongodb://claw:claw_secret@localhost:27017/claw_audit?authSource=admin

# Redis connection URL (shared instance for caching)
REDIS_URL=redis://localhost:6379

# RabbitMQ connection URL (shared async event bus)
RABBITMQ_URL=amqp://claw:claw_secret@localhost:5672

# JWT signing secret — must match auth service value
JWT_SECRET=change-me-to-a-random-64-char-string

# Service port
PORT=4007

# Allowed CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:80,http://localhost
