generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────

enum RoutingMode {
  AUTO
  MANUAL_MODEL
  LOCAL_ONLY
  PRIVACY_FIRST
  LOW_LATENCY
  HIGH_REASONING
  COST_SAVER
}

// ─── Models ──────────────────────────────────────────────

model RoutingDecision {
  id               String      @id @default(cuid())
  messageId        String?     @map("message_id")
  threadId         String      @map("thread_id")
  selectedProvider String      @map("selected_provider")
  selectedModel    String      @map("selected_model")
  routingMode      RoutingMode @map("routing_mode")
  confidence       Decimal?    @db.Decimal(5, 4)
  reasonTags       String[]    @map("reason_tags")
  privacyClass     String?     @map("privacy_class")
  costClass        String?     @map("cost_class")
  fallbackProvider String?     @map("fallback_provider")
  fallbackModel    String?     @map("fallback_model")
  createdAt        DateTime    @default(now()) @map("created_at")

  @@index([messageId])
  @@index([threadId])
  @@index([routingMode])
  @@index([createdAt])
  @@map("routing_decisions")
}

model RoutingPolicy {
  id          String      @id @default(cuid())
  name        String
  routingMode RoutingMode @map("routing_mode")
  priority    Int         @default(0)
  isActive    Boolean     @default(true) @map("is_active")
  config      Json
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  @@index([routingMode])
  @@index([isActive])
  @@index([priority])
  @@map("routing_policies")
}
