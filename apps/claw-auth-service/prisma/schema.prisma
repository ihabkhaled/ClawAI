generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("AUTH_DATABASE_URL")
}

enum UserRole {
  ADMIN
  OPERATOR
  VIEWER
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  PENDING
}

enum UserLanguagePreference {
  EN
  AR
  FR
  IT
  DE
  ES
  RU
  PT
}

enum UserAppearancePreference {
  SYSTEM
  LIGHT
  DARK
}

model User {
  id                 String     @id @default(cuid())
  email              String     @unique
  username           String     @unique
  passwordHash       String     @map("password_hash")
  role               UserRole   @default(VIEWER)
  status             UserStatus @default(PENDING)
  mustChangePassword    Boolean                  @default(false) @map("must_change_password")
  languagePreference    UserLanguagePreference   @default(EN) @map("language_preference")
  appearancePreference  UserAppearancePreference @default(SYSTEM) @map("appearance_preference")
  createdAt             DateTime                 @default(now()) @map("created_at")
  updatedAt             DateTime                 @updatedAt @map("updated_at")

  sessions Session[]

  @@index([email])
  @@index([status])
  @@map("users")
}

model Session {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  refreshToken String   @unique @map("refresh_token")
  expiresAt    DateTime @map("expires_at")
  createdAt    DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model SystemSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([key])
  @@map("system_settings")
}
