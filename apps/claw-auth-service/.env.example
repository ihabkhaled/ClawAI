# =============================================================================
# Auth Service Configuration
# =============================================================================

# PostgreSQL connection string for the auth database
DATABASE_URL=postgresql://claw:claw_secret@localhost:5441/claw_auth?schema=public

# Redis connection URL (shared instance for caching and sessions)
REDIS_URL=redis://localhost:6379

# RabbitMQ connection URL (shared async event bus)
RABBITMQ_URL=amqp://claw:claw_secret@localhost:5672

# JWT signing secret — CHANGE THIS in production (min 64 characters)
JWT_SECRET=change-me-to-a-random-64-char-string

# JWT access token expiry (e.g., 15m, 1h)
JWT_ACCESS_EXPIRY=15m

# JWT refresh token expiry (e.g., 7d, 30d)
JWT_REFRESH_EXPIRY=7d

# AES-256-GCM encryption key for sensitive data — CHANGE THIS in production
ENCRYPTION_KEY=change-me-to-a-random-32-byte-hex-string

# Service port
PORT=4001

# Allowed CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:80,http://localhost
