FROM node:20-alpine
RUN apk add --no-cache openssl
WORKDIR /app

COPY package.json ./package.json
COPY packages/ ./packages/
COPY apps/claw-file-generation-service/ ./apps/claw-file-generation-service/

RUN cd packages/shared-types && npm install --ignore-scripts 2>/dev/null || true && npx tsc 2>/dev/null || true
RUN cd packages/shared-constants && npm install --ignore-scripts 2>/dev/null || true && npx tsc 2>/dev/null || true
RUN cd packages/shared-rabbitmq && npm install --ignore-scripts 2>/dev/null || true && npx tsc 2>/dev/null || true
RUN cd packages/shared-auth && npm install --ignore-scripts 2>/dev/null || true && npx tsc 2>/dev/null || true

WORKDIR /app/apps/claw-file-generation-service
RUN npm install --ignore-scripts 2>/dev/null || npm install --legacy-peer-deps --ignore-scripts 2>/dev/null || true
RUN npx prisma generate 2>/dev/null || true
RUN chmod +x docker-entrypoint.dev.sh 2>/dev/null || true

EXPOSE 4013
CMD ["./docker-entrypoint.dev.sh"]
