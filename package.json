{
  "name": "claw",
  "version": "0.2.0",
  "private": true,
  "description": "Claw — Local-first AI orchestration platform (microservices)",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev:frontend": "npm run dev --workspace=claw-frontend",
    "build:frontend": "npm run build --workspace=claw-frontend",
    "lint:frontend": "npm run lint --workspace=claw-frontend",
    "test:frontend": "npm run test --workspace=claw-frontend",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "format": "prettier --write \"**/*.{ts,tsx,json,md,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md,css}\"",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:build": "docker compose build",
    "docker:up:full": "docker compose --profile local-ai up -d",
    "docker:up:gpu": "docker compose --profile gpu up -d",
    "docker:dev": "docker compose -f docker-compose.yml -f docker-compose.dev.yml up -d",
    "docker:dev:down": "docker compose -f docker-compose.yml -f docker-compose.dev.yml down",
    "docker:logs": "docker compose logs -f",
    "docker:ps": "docker compose ps",
    "prepare": "node .husky/install.mjs",
    "lint-staged": "lint-staged"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT",
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "eslint": "^9.39.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1"
  }
}
